# Application
APP_NAME=AI Sales Assistant CRM
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-secret-key-min-32-chars
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key-optional-fallback
AI_PRIMARY_PROVIDER=groq

# Google OAuth / APIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key
GMAIL_API_KEY=your-gmail-api-key

# Bland AI
BLAND_AI_API_KEY=your-bland-ai-org-key
BLAND_AI_BASE_URL=https://api.bland.ai/v1

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Scheduler
SCHEDULER_ENABLED=true
DAILY_REPORT_HOUR=8
MEETING_REMINDER_MINUTES=15

# Frontend URL
FRONTEND_URL=http://localhost:5173
.e
