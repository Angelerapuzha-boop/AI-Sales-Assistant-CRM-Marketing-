# Application
APP_NAME=AI Sales Assistant CRM
APP_ENV=development
DEBUG=true
SECRET_KEY=aisales-crm-secret-key-change-in-production-min-32-chars
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Database - Use Supabase PostgreSQL URL in production
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aisales

# Supabase (optional - for direct Supabase client features)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT
JWT_SECRET_KEY=aisales-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

